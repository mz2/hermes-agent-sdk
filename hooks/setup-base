#!/usr/bin/bash
set -euo pipefail

apt-get update
apt-get install ca-certificates curl git ripgrep ffmpeg \
    libffi-dev libolm-dev procps openssh-client

# Expose only the `hermes` entrypoint on PATH — NOT the whole venv bin/,
# which would shadow the system python3 for every login shell.
# /usr/local/bin is already on PATH for login and non-login shells.
install -d /usr/local/bin
ln -sf "$SDK/bin/hermes" /usr/local/bin/hermes
