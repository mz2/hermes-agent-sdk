#!/usr/bin/bash
# setup-project: write default config, provision secrets, install the gateway.
# Idempotent. Runs as the workshop user after setup-base.
set -euo pipefail

HERMES_HOME="$HOME/.hermes"

mkdir -p "$HERMES_HOME/skills" "$HERMES_HOME/plugins" "$HERMES_HOME/logs" "$HERMES_HOME/secrets"

# Default config.yaml — not overwritten on refresh.
if [ ! -f "$HERMES_HOME/config.yaml" ]; then
    cat > "$HERMES_HOME/config.yaml" <<'CONFIG'
# Hermes config — generated by the Workshop SDK on first launch.
# Edit freely; subsequent refreshes won't overwrite this file.
model:
  provider: custom
  # REQUIRED: set to a model on your llm-backend endpoint.
  default: ""
  base_url: http://localhost:11434/v1
  api_key: no-key-required

terminal:
  backend: local
  timeout: 180

memory:
  memory_enabled: true

logging:
  level: INFO
CONFIG
fi

# Secrets dir + .env symlink.
touch "$HERMES_HOME/secrets/.env"
chmod 700 "$HERMES_HOME/secrets"
chmod 600 "$HERMES_HOME/secrets/.env"
ln -sfn secrets/.env "$HERMES_HOME/.env"

# Gateway systemd user service — install and enable; user starts after configuring.
install -D --mode=644 --target-directory "$HOME/.config/systemd/user" \
    "$SDK/hermes-gateway.service"
systemctl --user daemon-reload
systemctl --user enable hermes-gateway.service
