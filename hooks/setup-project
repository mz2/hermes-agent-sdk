#!/usr/bin/bash
# setup-project: per-workshop user setup. Runs as the workshop user after
# setup-base, after interfaces are connected. Idempotent — re-running on
# refresh either short-circuits (version matches) or upgrades in place.
#
# What this does, in order:
#   1. Ensure ~/.hermes exists (mount plug target).
#   2. Install uv if missing.
#   3. Clone or fast-forward NousResearch/hermes-agent to the SDK's VERSION.
#   4. Create venv, run `uv pip install -e '.[all]'`.
#   5. Fetch Node 22 if missing (upstream installer pattern).
#   6. npm install + playwright chromium download (cached under ~/.cache/ms-playwright).
#   7. Write default config.yaml if absent.
#   8. Install + enable hermes-gateway systemd user unit.
set -euo pipefail

VERSION="$(cat "$SDK/VERSION")"
HERMES_HOME="$HOME/.hermes"
HERMES_SRC="$HERMES_HOME/hermes-agent"
NODE_DIR="$HERMES_HOME/node"
NODE_VERSION="22.11.0"  # matches upstream installer's "Node 22 LTS"

# Map dpkg arch -> Node release tarball arch. Ubuntu amd64 -> Node "x64";
# Ubuntu arm64 -> Node "arm64". Fail loudly on anything else so a future
# (e.g. ppc64el, riscv64) workshop can't silently pull the wrong binary.
case "$(dpkg --print-architecture)" in
    amd64) NODE_TARBALL_ARCH="linux-x64" ;;
    arm64) NODE_TARBALL_ARCH="linux-arm64" ;;
    *)
        echo "hermes-sdk: unsupported architecture $(dpkg --print-architecture)" >&2
        exit 1
        ;;
esac

mkdir -p "$HERMES_HOME"

# 1. uv -------------------------------------------------------------------
if ! command -v uv >/dev/null 2>&1; then
    curl -fsSL https://astral.sh/uv/install.sh | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# 2. Hermes source clone / version sync -----------------------------------
if [ ! -d "$HERMES_SRC/.git" ]; then
    git clone --depth=1 --branch "v${VERSION}" \
        https://github.com/NousResearch/hermes-agent.git "$HERMES_SRC"
else
    current_tag="$(git -C "$HERMES_SRC" describe --tags --exact-match 2>/dev/null || echo '')"
    if [ "$current_tag" != "v${VERSION}" ]; then
        git -C "$HERMES_SRC" fetch --tags --depth=1 origin "refs/tags/v${VERSION}:refs/tags/v${VERSION}"
        git -C "$HERMES_SRC" -c advice.detachedHead=false checkout "v${VERSION}"
    fi
fi

# 3. venv + Python deps ---------------------------------------------------
cd "$HERMES_SRC"
if [ ! -d "$HERMES_SRC/venv" ]; then
    uv venv venv --python 3.11
fi
# UV_LINK_MODE=copy avoids hardlink errors across the persisted mount.
UV_LINK_MODE=copy uv pip install -e '.[all]' --python "$HERMES_SRC/venv/bin/python"

# 4. Node 22 (bundled — Ubuntu 24.04 apt ships Node 18) -------------------
if [ ! -x "$NODE_DIR/bin/node" ]; then
    mkdir -p "$NODE_DIR"
    tmp="$(mktemp -d)"
    curl -fsSL -o "$tmp/node.tar.xz" \
        "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-${NODE_TARBALL_ARCH}.tar.xz"
    tar -xJf "$tmp/node.tar.xz" -C "$NODE_DIR" --strip-components=1
    rm -rf "$tmp"
fi
export PATH="$NODE_DIR/bin:$PATH"

# 5. npm deps + Playwright Chromium ---------------------------------------
if [ -f "$HERMES_SRC/package.json" ]; then
    (cd "$HERMES_SRC" && npm install --silent)
fi
# Playwright honours PLAYWRIGHT_BROWSERS_PATH; default location is the
# persisted ~/.cache/ms-playwright mount.
(cd "$HERMES_SRC" && npx --yes playwright install chromium) || true

# 6. Wrapper script in ~/.local/bin/hermes --------------------------------
mkdir -p "$HOME/.local/bin"
cat > "$HOME/.local/bin/hermes" <<'WRAPPER'
#!/bin/bash
# Hermes launcher — sourced PATH puts bundled Node ahead of system Node.
HERMES_SRC="$HOME/.hermes/hermes-agent"
export PATH="$HOME/.hermes/node/bin:$PATH"
exec "$HERMES_SRC/venv/bin/hermes" "$@"
WRAPPER
chmod +x "$HOME/.local/bin/hermes"

# 7. Default config.yaml (only if user hasn't supplied one) ---------------
if [ ! -f "$HERMES_HOME/config.yaml" ]; then
    cat > "$HERMES_HOME/config.yaml" <<'CONFIG'
# Hermes config — generated by the Workshop SDK on first launch.
# Edit freely; subsequent refreshes won't overwrite this file.
model:
  provider: custom
  default: qwen3.6:35b
  # Wired through the SDK's `llm-backend` tunnel plug. Connect that plug to
  # an Ollama-compatible OpenAI endpoint (Ollama itself, vLLM, LiteLLM, etc.)
  # and this endpoint will resolve correctly.
  base_url: http://localhost:11434/v1
  api_key: no-key-required

toolsets:
  - all
max_turns: 100

terminal:
  backend: local
  timeout: 180

memory:
  memory_enabled: true
  user_profile_enabled: true

# Set HERMES_TAVILY_API_KEY in ~/.hermes/secrets/.env to use Tavily web search.
web:
  backend: tavily

browser:
  inactivity_timeout: 120
  command_timeout: 30

logging:
  level: INFO

display:
  personality: kawaii

# Messaging platforms are disabled by default. Enable per platform after
# adding the relevant credentials (TELEGRAM_BOT_TOKEN, DISCORD_BOT_TOKEN,
# etc.) to ~/.hermes/secrets/.env.
platforms: {}
CONFIG
fi

# Ensure the secrets directory and .env file exist. The directory is itself a
# mount plug (hermes-secrets) — it may be auto-allocated by Workshop or
# remounted by the user to a host-managed path. Either way: mkdir is a no-op
# when already mounted, and touching .env makes the gateway's EnvironmentFile=
# directive succeed even before credentials are populated.
mkdir -p "$HERMES_HOME/secrets"
touch "$HERMES_HOME/secrets/.env"
chmod 700 "$HERMES_HOME/secrets"
chmod 600 "$HERMES_HOME/secrets/.env"

# Symlink ~/.hermes/.env -> secrets/.env so the hermes CLI (which loads
# ~/.hermes/.env directly) sees the same credentials as the gateway service.
# Migrate any pre-existing real .env file from older SDK versions.
if [ -e "$HERMES_HOME/.env" ] && [ ! -L "$HERMES_HOME/.env" ]; then
    cat "$HERMES_HOME/.env" >> "$HERMES_HOME/secrets/.env"
    rm "$HERMES_HOME/.env"
fi
ln -sfn secrets/.env "$HERMES_HOME/.env"

# 8. Install + enable gateway systemd user unit ---------------------------
install -D --mode=644 --target-directory "$HOME/.config/systemd/user" \
    "$SDK/hermes-gateway.service"
systemctl --user daemon-reload
systemctl --user enable --now hermes-gateway.service || true
