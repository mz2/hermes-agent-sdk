HERMES_HOME="$HOME/.hermes"

mkdir -p "$HERMES_HOME/skills" "$HERMES_HOME/plugins" "$HERMES_HOME/logs" "$HERMES_HOME/secrets"

# Default config.yaml — not overwritten on refresh.
if [ ! -f "$HERMES_HOME/config.yaml" ]; then
    cat > "$HERMES_HOME/config.yaml" <<'CONFIG'
# Hermes config — generated by the Workshop SDK on first launch.
# Edit freely; subsequent refreshes won't overwrite this file.
model:
  provider: custom
  # REQUIRED: set to a model on your llm-backend endpoint.
  default: ""
  base_url: http://localhost:11434/v1
  api_key: no-key-required

terminal:
  backend: local
  timeout: 180

memory:
  memory_enabled: true

logging:
  level: INFO
CONFIG
fi

# Secrets live in a plain subdir (not a mount) so Hermes atomic-writes stay on
# the same device as ~/.hermes and cross-device rename errors are avoided.
touch "$HERMES_HOME/secrets/.env"
chmod 700 "$HERMES_HOME/secrets"
chmod 600 "$HERMES_HOME/secrets/.env"
ln -sfn secrets/.env "$HERMES_HOME/.env"

# Register the gateway service via Hermes itself so the installed unit always
# matches the current upstream-generated definition. Called via $SDK/bin/hermes
# (not the /usr/local/bin symlink) so the uv venv resolves hermes_cli correctly
# during the hook, before the login-shell PATH is fully active.
# Only supports interactive mode at the moment — feed answers via stdin.
"$SDK/bin/hermes" gateway install <<'EOF'
Y
Y
EOF
