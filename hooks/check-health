#!/usr/bin/bash
# check-health: report SDK status to Workshop.
#
# Two checks: (1) hermes CLI is callable, (2) gateway is active. The gateway
# will commonly be in `activating`/`failed` until the user populates
# ~/.hermes/.env with messaging credentials — we report "waiting" with a
# remediation hint rather than "error" so the workshop surfaces guidance.
set -euo pipefail

if ! sudo -u workshop --login hermes --version >/dev/null 2>&1; then
    workshopctl set-health error "hermes CLI not available on PATH (setup-project did not complete)"
    exit 0
fi

if ! sudo -u workshop --login systemctl --user is-active --quiet hermes-gateway.service; then
    workshopctl set-health waiting "hermes-gateway not active — populate ~/.hermes/.env with platform credentials (TELEGRAM_BOT_TOKEN, DISCORD_BOT_TOKEN, …) then 'systemctl --user restart hermes-gateway'"
    exit 0
fi

workshopctl set-health okay
