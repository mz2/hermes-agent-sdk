#!/bin/bash
# hermes-mcp-add: add, update, or remove an entry in the mcp_servers: block of
# ~/.hermes/config.yaml, merging by NAME. An existing entry with the same name
# is replaced; every other part of the file is left untouched. Installed in the
# workshop by the Hermes Workshop SDK (hooks/setup-project).
#
# Usage:
#   hermes-mcp-add NAME --url URL [--header "K: V"]...          # HTTP transport
#   hermes-mcp-add NAME --command CMD [--arg A]... [--env K=V]...   # stdio
#   hermes-mcp-add NAME --remove
#
# Options (both transports):
#   --include TOOL     add TOOL to a tools.include allowlist (repeatable)
#   --keep-resources   keep MCP resource wrappers (default: resources: false)
#   --keep-prompts     keep MCP prompt wrappers   (default: prompts: false)
#
# HTTP auth helper (with --url):
#   --bearer-from FILE --bearer-var NAME
#       Read NAME=token from the dotenv FILE (e.g. another SDK's generated
#       token), copy it into ~/.hermes/secrets/.env, and add the header
#       Authorization: Bearer ${NAME}. No secret is typed on the CLI or written
#       literally into config.yaml.
#
# It edits config.yaml (and, with --bearer-from, secrets/.env). Apply the change
# with `systemctl --user restart hermes-gateway`, or `/reload-mcp` inside
# `hermes chat`. The `mcp-add` action in the example workshop.yaml wraps this
# helper and restarts the gateway.
#
# HERMES_HOME (default ~/.hermes) and HERMES_PY (default the hermes venv's
# python, which has PyYAML) can be overridden, e.g. for testing.
set -euo pipefail

HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
HERMES_PY="${HERMES_PY:-$HOME/hermes-agent/venv/bin/python}"
CONFIG="$HERMES_HOME/config.yaml"

exec "$HERMES_PY" - "$CONFIG" "$@" <<'PY'
import pathlib
import sys

import yaml

argv = sys.argv[1:]
config_path = pathlib.Path(argv[0])
args = argv[1:]
if not args or args[0].startswith("-"):
    sys.exit("usage: hermes-mcp-add NAME (--url URL | --command CMD | --remove) [...]")

name, rest = args[0], args[1:]
url = command = bearer_from = bearer_var = None
headers, env, cmd_args, include = {}, {}, [], []
remove = keep_resources = keep_prompts = False


def take(i):
    if i + 1 >= len(rest):
        sys.exit(f"hermes-mcp-add: {rest[i]} needs a value")
    return rest[i + 1]


i = 0
while i < len(rest):
    a = rest[i]
    if a == "--url":
        url = take(i); i += 2
    elif a == "--command":
        command = take(i); i += 2
    elif a == "--header":
        k, _, v = take(i).partition(":"); headers[k.strip()] = v.strip(); i += 2
    elif a == "--arg":
        cmd_args.append(take(i)); i += 2
    elif a == "--env":
        k, _, v = take(i).partition("="); env[k] = v; i += 2
    elif a == "--include":
        include.append(take(i)); i += 2
    elif a == "--bearer-from":
        bearer_from = take(i); i += 2
    elif a == "--bearer-var":
        bearer_var = take(i); i += 2
    elif a == "--remove":
        remove = True; i += 1
    elif a == "--keep-resources":
        keep_resources = True; i += 1
    elif a == "--keep-prompts":
        keep_prompts = True; i += 1
    else:
        sys.exit(f"hermes-mcp-add: unknown option {a!r}")


def env_key(line):
    s = line.strip()
    if s.startswith("export "):
        s = s[len("export "):]
    return s.split("=", 1)[0].strip()


def read_env_value(path, var):
    p = pathlib.Path(path)
    if not p.exists():
        sys.exit(f"hermes-mcp-add: --bearer-from file not found: {path}")
    for line in p.read_text().splitlines():
        if env_key(line) != var:
            continue
        v = line.split("=", 1)[1].strip()
        if len(v) >= 2 and v[0] == v[-1] and v[0] in "\"'":
            v = v[1:-1]
        return v
    return None


def set_secret(secrets_path, var, value):
    secrets_path.parent.mkdir(parents=True, exist_ok=True)
    kept = []
    if secrets_path.exists():
        kept = [l for l in secrets_path.read_text().splitlines() if env_key(l) != var]
    secrets_path.write_text("\n".join(kept + [f"{var}={value}"]) + "\n")
    secrets_path.chmod(0o600)


cfg = (yaml.safe_load(config_path.read_text()) if config_path.exists() else {}) or {}
servers = cfg.get("mcp_servers")
if not isinstance(servers, dict):
    servers = {}
    cfg["mcp_servers"] = servers

if remove:
    if servers.pop(name, None) is None:
        sys.exit(f"hermes-mcp-add: no mcp_servers entry named {name!r}")
    print(f"Removed mcp_servers.{name}")
else:
    if (url is None) == (command is None):
        sys.exit("hermes-mcp-add: give exactly one of --url or --command")
    if bearer_from is not None and url is None:
        sys.exit("hermes-mcp-add: --bearer-from only applies to --url")
    entry = {}
    if url is not None:
        entry["url"] = url
        if bearer_from is not None:
            if bearer_var is None:
                sys.exit("hermes-mcp-add: --bearer-from requires --bearer-var")
            token = read_env_value(bearer_from, bearer_var)
            if token is None:
                sys.exit(f"hermes-mcp-add: {bearer_var} not found in {bearer_from}")
            set_secret(config_path.parent / "secrets" / ".env", bearer_var, token)
            headers["Authorization"] = "Bearer ${%s}" % bearer_var
        if headers:
            entry["headers"] = headers
    else:
        entry["command"] = command
        if cmd_args:
            entry["args"] = cmd_args
        if env:
            entry["env"] = env
    tools = {}
    if include:
        tools["include"] = include
    if not keep_resources:
        tools["resources"] = False
    if not keep_prompts:
        tools["prompts"] = False
    if tools:
        entry["tools"] = tools
    servers[name] = entry
    print(f"Set mcp_servers.{name} -> {url if url is not None else command}")

config_path.parent.mkdir(parents=True, exist_ok=True)
config_path.write_text(yaml.safe_dump(cfg, sort_keys=False))
PY
